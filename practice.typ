// ============================================================================
// 📚 ОТЧЁТ ПО ТЕХНОЛОГИЧЕСКОЙ (ПРОЕКТНО-ТЕХНОЛОГИЧЕСКОЙ) ПРАКТИКЕ
// ============================================================================
//
// Отдельная точка входа, собирающая урезанный PDF для технологической практики.
// Оригиналы ВКР (main.typ, chapters/*, template.typ) не затрагиваются.
//
// В отчёт включены:
//   — технологический раздел (chapters/04-tech.typ) — выбор стека,
//     данные, интерфейс, тестирование, развёртывание;
//   — список используемых источников.
//
// Титульный лист и задание в PDF не включаются — прикрепляются вручную.
// Нумерация страниц отключена.
//
// Компиляция:
//   typst compile practice.typ СуховВА_Технологическая_практика.pdf
//   just build-practice
// ============================================================================

#import "template.typ": *
#import "meta.typ": meta
#import "sources.typ": sources

// Метаданные PDF (имя файла всё равно задаёт пользователь при компиляции)
#set document(
  title: "Отчёт по технологической практике — " + meta.student,
  author: meta.student,
)

// Применяем общие стили ВКР (шрифты, поля, заголовки, таблицы, листинги)
#show: doc => vkr-doc(meta, doc)

// Отключаем нумерацию страниц для всего отчёта
#set page(numbering: none)

// Первый раздел — без принудительного pagebreak перед ним (template
// добавляет weak pagebreak к каждому level-1 заголовку, но на самой
// первой странице он схлопывается, так что открываем сразу с заголовка).

// === ТЕХНОЛОГИЧЕСКИЙ РАЗДЕЛ ===
#include "chapters/04-tech.typ"

// ---------------------------------------------------------------------------
// Листинг, на который ссылается технологический раздел.
// В полной ВКР он размещён в проектном разделе; для самостоятельного
// отчёта по практике приводим его здесь, чтобы ссылка <lst:dir-tree>
// разрешалась корректно и у читателя был нужный справочный материал.
// ---------------------------------------------------------------------------
#vkr-code-file(
  "input/code/dir-tree.txt",
  caption: [Структура репозитория системы vladOS],
  lang: "bash",
) <lst:dir-tree>

// === СПИСОК ИСПОЛЬЗУЕМЫХ ИСТОЧНИКОВ ===
#vkr-sources(sources)
